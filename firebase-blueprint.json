{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including photo and basic info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName1": { "type": "string" },
        "photoUrl": { "type": "string" },
        "gallery": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantDetails": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastMessageSenderId": { "type": "string" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "lastUpdatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A transaction entry in a user's wallet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "payment", "withdrawal"] },
        "amount": { "type": "number" },
        "label": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "label", "category", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
